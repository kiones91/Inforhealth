# URLs limpas (sem .html) — Apache / cPanel
Options -MultiViews
RewriteEngine On
RewriteBase /

# Canonical: /pagina.html -> /pagina (301)
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Nao reescrever arquivos e pastas reais
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# /pagina -> /pagina.html
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
